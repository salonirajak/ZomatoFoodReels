# JWT secret for token generation
JWT_SECRET=

# MongoDB Connection String
# Option 1 - Local MongoDB: mongodb://localhost:27017/zomato
# Option 2 - MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/zomato
MONGODB_URL=

# ImageKit Configuration (for image/video processing)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=